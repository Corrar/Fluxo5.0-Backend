# ─────────────────────────────────────────────────────────────
# Fluxo Royale 5.0 — Backend · variáveis de ambiente (EXEMPLO)
# Copie este arquivo para `.env` e preencha os valores.
# NUNCA comite o `.env` real — ele já está no .gitignore.
# (Valores abaixo são apenas placeholders, sem nenhum segredo real.)
# ─────────────────────────────────────────────────────────────

# ── Obrigatórias ──
# Connection string do PostgreSQL (Neon). Use a URL "pooled" para runtime.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Segredo de assinatura dos tokens JWT — use um valor longo e aleatório.
JWT_SECRET=

# ── Servidor (opcional — tem default no código) ──
PORT=3000                       # porta HTTP (default: 3000)

# ── Pool / SSL do Postgres (opcional — defaults em src/db.ts) ──
PG_SSL=                         # "false" desliga TLS (só p/ Postgres local); vazio = SSL ligado (Neon exige)
PG_POOL_MAX=10                  # máximo de conexões no pool (default: 10)

# ── Timeouts + retry (ms) — tolerância a COLD START do Neon serverless ──
PG_CONNECT_TIMEOUT=20000        # timeout de conexão/handshake (default: 20000) — margem p/ wake do compute
PG_QUERY_TIMEOUT=15000          # timeout client-side por tentativa de RETRY (default: 15000)
PG_QUERY_TIMEOUT_FIRST=6000     # timeout da 1ª tentativa — curto p/ derrubar cold start rápido (default: 6000)
PG_STATEMENT_TIMEOUT=15000      # timeout server-side de statement (default: = PG_QUERY_TIMEOUT)
PG_RETRY_ATTEMPTS=3             # nº total de tentativas em erro transitório de conexão (default: 3)
# Nomes legados ainda aceitos como fallback: PG_CONNECT_TIMEOUT_MS, PG_QUERY_TIMEOUT_MS, PG_STATEMENT_TIMEOUT_MS

# ── Notificações WhatsApp via Green API (opcional) ──
# Sem estas três, o alerta de WhatsApp é apenas registrado no log (não quebra o app).
GREEN_API_ID=                   # ID da instância Green API
GREEN_API_TOKEN=                # token da instância Green API
ALMOXARIFADO_PHONE=             # número de destino do alerta (ex.: 55DDDNUMERO)

# ── Rastreio de encomendas via Wonca Labs ──
WONCA_API_KEY=                  # API key da Wonca (tracking) — NUNCA commitar valor real

# ── Armazém de material por OP (módulo Produção) ──
# Data de go-live do per-OP (ISO, YYYY-MM-DD). A fila do Recebimento
# (GET /op-materials/pending-receipts) só mostra separação ENTREGUE a partir desta data —
# COALESCE(sent_at, created_at) >= cutoff. Sem ela, a fila nasceria com ~77 separações desde
# fev/2026: material que saiu do almox há meses e já foi consumido, que ninguém vai receber.
# Ausente/vazia -> fallback '2026-07-17' (hardcoded em opMaterials.controller.ts).
PEROP_CUTOFF_DATE=2026-07-17
